# Exclude specific files from archives generated by git archive.
/.claude export-ignore
/.github export-ignore
/.travis.yml export-ignore
/.gitattributes export-ignore
/CLAUDE.md export-ignore
/DEVELOPER-GUIDE.md export-ignore
/INSTALLATION.md export-ignore
/USER-GUIDE.md export-ignore
/LICENSE.txt
/COPYING.txt
/CHANGELOG.md export-ignore
/COPY.md export-ignore
/COMMERCIAL.md export-ignore
/README.md

# Documentation files should be excluded from archives generated by git archive.
/docs export-ignore
/Docs export-ignore

# Mark files as binary to prevent Git from attempting to diff or merge them.
*.png binary
*.jpg binary
*.zip binary

# Text files should have normalized line endings
* text=auto
*.txt text
*.html text
*.css text
*.php text
*.phtml text
*.js text
